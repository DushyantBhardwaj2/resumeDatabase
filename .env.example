# ── Backend (Render) ───────────────────────────────────────────────────────────

# Database connection (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/resumint?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI API (OpenAI-compatible — OpenCode Zen or OpenAI)
OPENCODE_API_KEY="sk-..."

# Frontend URL for CORS (must match the Vercel frontend domain in production)
VERCEL_FRONTEND_URL="http://localhost:3000"

# Server port (default 8080)
PORT=8080

# Node environment
NODE_ENV=development

# ── Frontend (Vercel) ──────────────────────────────────────────────────────────

# Backend API URL (Render backend in production, localhost in dev)
NEXT_PUBLIC_API_URL="http://localhost:8080"

# Frontend app URL (used by Better Auth client)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
