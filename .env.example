# ── Required on both Vercel (Next.js) and Render (Express backend) ────────────

# Database connection (PostgreSQL via Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/resumint?schema=public"

# Better Auth
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="https://your-app.vercel.app"        # Must point to Vercel domain (for OAuth callbacks)

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# AI API (OpenAI-compatible)
OPENCODE_API_KEY="sk-..."

# ── Render-specific ───────────────────────────────────────────────────────────

# Allowed CORS origin (Vercel frontend URL)
CORS_ORIGIN="https://your-app.vercel.app"

# ── Vercel-specific ───────────────────────────────────────────────────────────

# Public app URL (used by frontend)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
