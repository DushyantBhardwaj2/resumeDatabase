{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "vercel": {
      "type": "remote",
      "url": "https://mcp.vercel.com",
      "headers": {
        "x-vercel-token": "{env:VERCEL_ACCESS_TOKEN}"
      }
    },
    "render": {
      "type": "remote",
      "url": "https://mcp.render.com/mcp",
      "headers": {
        "Authorization": "Bearer {env:RENDER_API_KEY}"
      }
    }
  }
}
